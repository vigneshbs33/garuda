# GARUDA — Environment Variables
# Copy to .env and fill in your values.
# DO NOT commit .env to version control.

# ===== App =====
APP_NAME=GARUDA
APP_VERSION=1.0.0
DEBUG=true
SECRET_KEY=REPLACE_WITH_LONG_RANDOM_SECRET

# ===== Server =====
HOST=0.0.0.0
PORT=8000
ALLOWED_ORIGINS=*

# ===== Database =====
# Dev (SQLite — no setup needed):
DATABASE_URL=sqlite+aiosqlite:///./garuda.db
# Prod (PostgreSQL — change user/pass/host):
# DATABASE_URL=postgresql+asyncpg://garuda_user:secure_password@localhost:5432/garuda

# ===== Evidence Storage =====
EVIDENCE_DIR=evidence

# ===== ML Model =====
# Leave empty to auto-download yolo11n.pt (~6 MB on first run)
MODEL_PATH=
# Use "cpu", "cuda:0", or "0" for GPU
DEVICE=cpu
# Stop line pixel Y coordinate (calibrate per camera)
STOP_LINE_Y=380
# Confidence thresholds (see BACKEND_REFERENCE.md for explanation)
CONFIDENCE_TIER1=0.90
CONFIDENCE_TIER2=0.60

# ===== Twilio Alerts (optional — leave empty for mock mode) =====
ALERTS_ENABLED=false
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=+14155238886
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Officer phone numbers (comma-separated, with country code)
OFFICER_PHONES=+919999999999,+918888888888

# ===== Federated Learning =====
FL_ENABLED=false
FL_SERVER_ADDRESS=localhost:8080

# ===== Camera Heartbeat =====
CAMERA_TIMEOUT_SEC=30
